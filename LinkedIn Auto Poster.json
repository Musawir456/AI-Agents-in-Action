    {
      "parameters": {
        "jsCode": "const rawText = $json.text || \"\";\n\n// Remove code block markers\nlet cleaned = rawText.replace(/```json|```/g, '').trim();\n\nlet finalText = \"\";\ntry {\n  // Parse the JSON if valid\n  const parsed = JSON.parse(cleaned);\n  finalText = parsed.headline || \"\";\n} catch (e) {\n  // If parsing fails, try to clean manually\n  finalText = cleaned.replace(/^{|}$/g, '')\n                     .replace(/\"headline\":/i, '')\n                     .replace(/[\"{}]/g, '')\n                     .trim();\n}\n\n// Return only the raw string\nreturn [{ json: { text: finalText } }];"
      },
